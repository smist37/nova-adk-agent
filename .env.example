# Pick ONE of the two auth modes below.

# Option A: Gemini API key (simplest for local dev)
# Get one from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Option B: Vertex AI on GCP (uses application default credentials).
# Uncomment this block AFTER verifying the project ID below.
#
# NOTE: gen-lang-client-0034704607 is the project Miles currently points the
# Gemini API key at. VERIFY BEFORE DEPLOY that:
#   - this project is billing-enabled
#   - the Vertex AI API is enabled in it
#   - the staging GCS bucket exists (see nova_adk_agent/deploy/config.yaml)
# If any of those is uncertain, pick a different project or create one first.
# GOOGLE_CLOUD_PROJECT=gen-lang-client-0034704607
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_CLOUD_STAGING_BUCKET=gs://gen-lang-client-0034704607-adk-staging
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
